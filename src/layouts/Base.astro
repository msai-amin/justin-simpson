---
// Self-hosted fonts (offline-safe). Physis: Fraunces + Spectral. Technê: IBM Plex Mono.
import "@fontsource/fraunces/400.css";
import "@fontsource/fraunces/500.css";
import "@fontsource/fraunces/600.css";
import "@fontsource/fraunces/400-italic.css";
import "@fontsource/fraunces/600-italic.css";
import "@fontsource/spectral/300.css";
import "@fontsource/spectral/400.css";
import "@fontsource/spectral/500.css";
import "@fontsource/spectral/600.css";
import "@fontsource/ibm-plex-mono/400.css";
import "@fontsource/ibm-plex-mono/500.css";
import "@fontsource/ibm-plex-mono/600.css";

import "../styles/global.css";
import "../styles/modes.css";

// base-safe asset prefix (works at a subpath like /justin-simpson and at root)
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const {
  title = "Justin Simpson — Continental Philosophy of Environment & Technology",
  description = "Justin Simpson is a philosopher of environment and technology and author of Toward an Environmental Ethic of Surprise (2025) — working across environmental ethics, social epistemology, and the more-than-human world.",
} = Astro.props;

const person = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Justin Simpson",
  jobTitle: "Assistant Professor",
  affiliation: {
    "@type": "CollegeOrUniversity",
    name: "Marshall University",
  },
  alumniOf: [
    { "@type": "CollegeOrUniversity", name: "University of Georgia" },
    { "@type": "CollegeOrUniversity", name: "University of North Florida" },
  ],
  knowsAbout: [
    "Continental philosophy",
    "Environmental ethics",
    "Philosophy of technology",
    "Social epistemology",
    "New materialism",
    "Posthumanism",
    "Phenomenology",
  ],
  sameAs: ["https://philpeople.org/profiles/justin-simpson"],
};
---

<!doctype html>
<html lang="en" data-mode="physis">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href={`${base}/favicon.svg`} type="image/svg+xml" />
    <link rel="icon" href={`${base}/favicon.ico`} sizes="any" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Justin Simpson" />

    <meta property="og:type" content="profile" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content="summary_large_image" />

    {/* No-flash: set the mode before first paint. */}
    <script is:inline>
      (function () {
        try {
          var m = localStorage.getItem("mode");
          if (m !== "physis" && m !== "techne") {
            m = window.matchMedia("(prefers-color-scheme: dark)").matches
              ? "techne"
              : "physis";
          }
          document.documentElement.setAttribute("data-mode", m);
        } catch (e) {
          document.documentElement.setAttribute("data-mode", "physis");
        }
      })();
    </script>

    <script type="application/ld+json" set:html={JSON.stringify(person)} />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <div class="sweep" id="sweep" aria-hidden="true"></div>
    <slot />
  </body>
</html>
