---
// The CV PDF (public/cv.pdf) is generated by scripts/build_cv_pdf.py — a clean,
// public-safe copy that omits the References section and Justin's personal cell.
// Re-run `python3 scripts/build_cv_pdf.py` to regenerate it.
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<section class="cv reveal" id="cv">
  <div class="wrap">
    <div class="section-head">
      <span class="index">04 — Curriculum Vitae</span>
      <h2>The short version</h2>
      <span class="rule"></span>
    </div>

    <div class="panel">
      <div class="grid">
        <div>
          <p>
            I'm a philosopher of environment and technology, writing across
            environmental ethics, social epistemology, and the new materialisms —
            and, in my 2025 book, a practice of attention and surprise.
          </p>
          <p style="margin-top:1.4rem">
            <a class="btn btn--primary" href={`${base}/cv.pdf`} target="_blank" rel="noopener">
              Download CV (PDF)
            </a>
          </p>
        </div>

        <ul class="facts">
          <li>
            <span class="k">Position</span>
            <span class="v">Assistant Professor in Humanities <small>· Marshall University</small></span>
          </li>
          <li>
            <span class="k">Specialization</span>
            <span class="v">Environmental ethics · Social epistemology · New materialisms · Science &amp; technology studies</span>
          </li>
          <li>
            <span class="k">Competence</span>
            <span class="v">Ethics of technology · Bioethics · Indigenous philosophies · Food ethics · Logic</span>
          </li>
          <li>
            <span class="k">Education</span>
            <span class="v">Ph.D., University of Georgia (2022) <small>· M.A. &amp; B.S., University of North Florida</small></span>
          </li>
          <li>
            <span class="k">Dissertation</span>
            <span class="v"><i>Posthuman Performances in Environmental Ethics and Social Epistemology</i></span>
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>
